# FastClaw Runtime Configuration
# Copy to env.toml and modify as needed.
# Environment variables override these values (see comments).

[gateway]
port = 18953                    # FASTCLAW_PORT
mode = "local"                  # FASTCLAW_MODE: "local" (single user) or "cloud" (multi-tenant)
bind = "loopback"               # FASTCLAW_BIND: "loopback" or "all"
token = ""                      # FASTCLAW_AUTH_TOKEN: gateway admin token (auto-generated if empty)

[storage]
# Default is sqlite at ~/.fastclaw/fastclaw.db — zero-config dev.
# Use postgres for multi-pod cloud deployments. "file" is back-compat
# for single-user installs that predate the DB-primary refactor.
type = "sqlite"                 # FASTCLAW_STORAGE_TYPE: "sqlite", "postgres", or "file"
dsn = ""                        # FASTCLAW_STORAGE_DSN: empty = sqlite at ~/.fastclaw/fastclaw.db
auto_migrate = true             # auto-create tables on startup

# Examples:
# type = "postgres"
# dsn = "postgres://user:pass@localhost:5432/fastclaw?sslmode=disable"
#
# type = "sqlite"
# dsn = "file:./data/fastclaw.db?_journal=WAL"

[sandbox]
enabled = false                 # enable sandbox for code execution
backend = "docker"              # "docker" or "e2b"
image = "python:3.12-slim"      # docker image (ignored for e2b)
e2b_key = ""                    # E2B_API_KEY: E2B API key (for e2b backend)

[log]
level = "info"                  # "debug", "info", "warn", "error"
